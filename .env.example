# ── Copy this file to .env and fill in real values. .env is gitignored. ──

# ── LLM provider ──────────────────────────────────────────────────────
# openai (cloud) or ollama (local). Default: ollama.
LLM_PROVIDER=openai

# Required if LLM_PROVIDER=openai. Get a key at:
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-replace-me

# Optional model override. Default: gpt-4o-mini.
# OPENAI_MODEL=gpt-4o

# Optional Ollama model override (only used if LLM_PROVIDER=ollama).
# OLLAMA_MODEL=qwen2:7b

# ── MCP transport ─────────────────────────────────────────────────────
# stdio (subprocess per agent) or http (shared persistent services).
# Default: stdio. Use http when running the full stack via scripts/stack.sh.
MCP_TRANSPORT=http

# ── Supabase (Postgres) ───────────────────────────────────────────────
# Session Pooler connection string from Supabase dashboard:
#   Project Settings → Database → Connection string → URI → Session Pooler
# Replace [YOUR-PASSWORD] with the database password set at project creation.
SUPABASE_DATABASE_URL=postgresql://postgres.your-project-ref:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Supabase API keys — new format (Publishable + Secret).
# Get from: Project Settings → API
# Publishable: safe to expose client-side (replaces legacy anon key).
# Secret: server-only, NEVER commit, NEVER expose (replaces legacy service_role).
SUPABASE_PUBLISH_KEY=sb_publishable_replace_me
SUPABASE_SECRET_KEY=sb_secret_replace_me

# ── Agent safety cap (optional) ───────────────────────────────────────
# Max LangGraph steps per agent request before GraphRecursionError.
# AGENT_RECURSION_LIMIT=20

# ── Langfuse observability (OpenTelemetry export) ─────────────────────
# Sign up at https://langfuse.com → create project → Settings → API Keys.
# Pick the BASE_URL that matches the cloud region you signed up for:
#   US: https://us.cloud.langfuse.com
#   EU: https://cloud.langfuse.com
# If unset, observability falls through silently (no tracing, no errors).
LANGFUSE_PUBLIC_KEY=pk-lf-replace-me
LANGFUSE_SECRET_KEY=sk-lf-replace-me
LANGFUSE_BASE_URL=https://us.cloud.langfuse.com
